{
    "layer": "top",
    "height": 30,
    "spacing": 8,
    "fixed-center": false,

    "modules-left": ["hyprland/workspaces", "hyprland/submap"],
    "modules-center": ["hyprland/window"],
    "modules-right": ["idle_inhibitor", "mpris", "group/media", "backlight", "group/network", "group/hardware", "battery", "clock", "custom/notification", "tray"],

    "group/media": {
      "modules": ["pulseaudio"],
      "orientation": "horizontal",
    },
    "group/network": {
      "modules": ["network", "network#bandwidth"],
      "orientation": "horizontal",
      "drawer": {
        "transition-duration": 250,
        "transition-left-to-right": false,
      },
    },
    "group/hardware": {
      "orientation": "horizontal",
      "drawer": {
        "transition-duration": 250,
        "transition-left-to-right": false,
      },
      "modules": ["cpu", "disk", "memory", "temperature"]
    },
    // Modules configuration
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        //"format": "{name}",
        "format": "{name}: {icon} ",
        "format-icons": {
            "1": "п‰©",
            "2": "п‰©",
            //"3": "п„Ў",
            "3": "п‰©",
            //"4": "п†ј",
            "4": "п…„",
            //"5": "пЃµ",
            "7": "п‰©",
            "8": "п„ ",
            "urgent": "пЃЄ",
            "focused": "п†’",
            "default": "п„‘"
        }
    },
    "hyprland/window": {
      "max-length": 200,
      "separate-outputs": true,
      "format": "{title}",
      "icon": true,
      "icon-size": 15,
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "пЃ® ",
            "deactivated": "пЃ° "
        }
    },
    "custom/notification": {
      "tooltip": false,
      "format": "{} {icon}",
      "format-icons": {
        "notification": "у±…« ",
        "none": "пѓі",
        "dnd-notification": "п‡¶ ",
        "dnd-none": "у°‚›",
        "inhibited-notification": "п‚ў ",
        "inhibited-none": "п‚ў",
        "dnd-inhibited-notification": "п‡· ",
        "dnd-inhibited-none": "п‡· ",
      },
      "return-type": "json",
      "exec-if": "which swaync-client",
      "exec": "swaync-client -swb",
      "on-click": "sleep 0.1 && swaync-client -t -sw",
      "on-click-right": "sleep 0.1 && swaync-client -d -sw",
      "escape": true,
    },
    "tray": {
         "icon-size": 16,
        "spacing": 10
    },
    "clock": {
        "format-alt": "{:%H:%M} пЂ—",
        "format": "{:%a %d.%m. п„і   %H:%M} пЂ—",
        "tooltip-format": "{:%Y-%m-%d  |  week %U  |  %A  |  %H:%M:%S}",
    },
    "cpu": {
        "format": "{usage}% п‹›",
        "tooltip": false
    },
    "memory": {
        "format": "{}% пѓ‰ "
    },
    "disk": {
      "format": "{percentage_used}% п‚  "
    },
    "temperature": {
        // "thermal-zone": 2,
        "hwmon-path": "/sys/class/hwmon/hwmon5/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}В°C {icon}",
        "format": "{temperatureC}В°C {icon}",
        //"format": "{temperatureC}В°C {icon}",
        "format-icons": ["пќ«", "п‹‰", "пќ©"]
    },
    "backlight": {
        // fails now, see https://github.com/Alexays/Waybar/issues/3302
        //"device": "intel_backlight",
        "format": "{percent}% {icon}",
        "format-icons": ["п†…", "п„‘"]
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% п—§",
        "format-plugged": "{capacity}% п‡¦",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"]
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{signalStrength}% п‡«",
        "format-ethernet": "eth пћ–",
        "format-linked": "{ifname} (No IP) пћ–",
        "format-disconnected": "Disconnected вљ ",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "tooltip-format-wifi": "{essid} ({signalStrength}%) п‡«",
        "tooltip-format-ethernet": "{ifname}: {ipaddr}/{cidr}",
    },
    "network#bandwidth": {
      "format": "{bandwidthUpBits} п‚Є  {bandwidthDownBits} п‚« ",
      "interval": 1
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{volume}% {icon}  {format_source}",
        "format-bluetooth": "{volume}% {icon} пЉ” {format_source}",
        "format-bluetooth-muted": "пљ© {icon} пЉ” {format_source}",
        "format-muted": "пљ© {format_source}",
        "format-source": "{volume}% п„°",
        "format-source-muted": "п„± ",
        "format-icons": {
            "headphones": "пЂҐ ",
            "handsfree": "п–ђ ",
            "headset": "п–ђ ",
            "phone": "п‚•",
            "portable": "п‚•",
            "car": "п†№",
            "default": ["пЂ¦ ", "пЂ§ ", "пЂЁ "]
        },
        "on-click": "pavucontrol"
    },
    "mpris": {
      //"format": "{dynamic} {player_icon}",
      "format": "{player_icon}",
      //"format-paused": "<i>{dynamic}</i>{status_icon}",
      "format-paused": "{status_icon}",
      "tooltip-format": "{dynamic} ({player})",
      "player-icons": {
           "default": "в–¶",
           "spotify": "п†ј ",
           "mpv": "рџЋµ"
      },
      "status-icons": {
           "paused": "вЏё"
      },
      // "ignored-players": ["firefox"]
      "interval": 1,
      "album-len": 0,
      "artist-len": 0,
      "rotate": 0
    },
}
